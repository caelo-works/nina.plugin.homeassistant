<ResourceDictionary
    x:Class="NinaHA.Plugin.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:NinaHA.Plugin.Controls">

    <!--  Tabler-style stroke icons (24x24 view box).  -->
    <StreamGeometry x:Key="HaIcon_Refresh">M20 11a8.1 8.1 0 0 0 -15.5 -2m-.5 -4v4h4 M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4</StreamGeometry>
    <StreamGeometry x:Key="HaIcon_Plus">M12 5l0 14 M5 12l14 0</StreamGeometry>
    <StreamGeometry x:Key="HaIcon_Save">M6 4h10l4 4v10a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2v-12a2 2 0 0 1 2 -2 M12 14m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0 M14 4l0 4l-6 0l0 -4</StreamGeometry>
    <StreamGeometry x:Key="HaIcon_Trash">M4 7l16 0 M10 11l0 6 M14 11l0 6 M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12 M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3</StreamGeometry>

    <Style x:Key="IconPath" TargetType="Path">
        <Setter Property="Width" Value="15" />
        <Setter Property="Height" Value="15" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Fill" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeEndLineCap" Value="Round" />
        <Setter Property="StrokeLineJoin" Value="Round" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Stroke" Value="{DynamicResource ButtonForegroundBrush}" />
    </Style>

    <!--  Data context: an instance of HomeAssistantSwitchPlugin.  -->
    <!--  Key convention: "<AssemblyTitle>_Options".  -->
    <DataTemplate x:Key="Home Assistant_Options">
        <StackPanel Margin="10" Orientation="Vertical">

            <!--  ============ Header ============  -->
            <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                <Image
                    Width="40"
                    Height="40"
                    VerticalAlignment="Center"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    Source="pack://application:,,,/NinaHA.Plugin;component/Resources/logo.png" />
                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Text="Home Assistant" />
            </StackPanel>

            <!--  ============ Connection ============  -->
            <GroupBox Margin="0,0,0,10" Header="Home Assistant connection">
                <StackPanel Margin="8" Orientation="Vertical">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Center" Text="Base URL" />
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4" Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" ToolTip="e.g. http://homeassistant.local:8123" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Center" Text="Token" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4" Text="{Binding Token, UpdateSourceTrigger=PropertyChanged}" ToolTip="Long-lived access token" />

                        <CheckBox Grid.Row="2" Grid.Column="1" Margin="0,6" Content="Use WebSocket for live updates (REST fallback)" IsChecked="{Binding UseWebSocket}" />
                    </Grid>

                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                        <Button HorizontalContentAlignment="Left" Padding="16,6,16,6" Command="{Binding TestConnectionCommand}">
                            <StackPanel Orientation="Horizontal" Margin="10,3">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource HaIcon_Refresh}" />
                                <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="Test connection" />
                            </StackPanel>
                        </Button>
                        <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Text="{Binding StatusMessage}" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!--  ============ Switch ============  -->
            <GroupBox Header="Switch channels">
                <StackPanel Margin="8" Orientation="Vertical">
                    <DataGrid
                        MinHeight="160"
                        MaxHeight="320"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        HeadersVisibility="Column"
                        ItemsSource="{Binding Rows}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="1.4*" MinWidth="90" Header="Name">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Margin="2" BorderThickness="0" Background="Transparent" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="2.2*" MinWidth="170" Header="Entity">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ctrl:SearchComboBox
                                            Margin="2"
                                            SourceItems="{Binding DataContext.Catalog.Entities, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            Text="{Binding EntityId, UpdateSourceTrigger=LostFocus}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="Auto" Header="Type">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox
                                            MinWidth="110"
                                            Margin="2"
                                            ItemsSource="{Binding DataContext.ChannelTypes, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="Auto" Header="Direction">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox
                                            MinWidth="120"
                                            Margin="2"
                                            ItemsSource="{Binding DataContext.ChannelDirections, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            SelectedItem="{Binding Direction, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="1*" MinWidth="80" Header="Preview">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="6,0" VerticalAlignment="Center" Text="{Binding Preview}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button
                                            Margin="3,2"
                                            Padding="14,4,14,4"
                                            Command="{Binding DataContext.RemoveChannelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Remove this channel">
                                            <Path Style="{StaticResource IconPath}" Data="{StaticResource HaIcon_Trash}" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                        <Button HorizontalContentAlignment="Left" Padding="16,6,16,6" Command="{Binding AddChannelCommand}">
                            <StackPanel Orientation="Horizontal" Margin="10,3">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource HaIcon_Plus}" />
                                <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="Add channel" />
                            </StackPanel>
                        </Button>
                        <Button Margin="8,0,0,0" HorizontalContentAlignment="Left" Padding="16,6,16,6" Command="{Binding SaveCommand}">
                            <StackPanel Orientation="Horizontal" Margin="10,3">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource HaIcon_Save}" />
                                <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="Save" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBlock
                        Margin="0,10,0,0"
                        FontStyle="Italic"
                        TextWrapping="Wrap"
                        Text="After saving, connect the 'Home Assistant' device from Equipment &gt; Switch. Binary = on/off, Stepped = discrete options (e.g. select), Analog = numeric (min/max/step from the entity)." />
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </DataTemplate>
</ResourceDictionary>
