<ResourceDictionary
    x:Class="NinaHA.Plugin.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Data context: an instance of HomeAssistantSwitchPlugin.  -->
    <!--  Key convention: "<AssemblyTitle>_Options".  -->
    <DataTemplate x:Key="Home Assistant Switch_Options">
        <StackPanel Margin="10" Orientation="Vertical">

            <!--  Connection  -->
            <TextBlock Margin="0,0,0,6" FontWeight="Bold" Text="Home Assistant connection" />

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Center" Text="Base URL" />
                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4" Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" ToolTip="e.g. http://homeassistant.local:8123" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Center" Text="Token" />
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4" Text="{Binding Token, UpdateSourceTrigger=PropertyChanged}" ToolTip="Long-lived access token" />

                <CheckBox Grid.Row="2" Grid.Column="1" Margin="0,6" Content="Use WebSocket for live updates (REST fallback)" IsChecked="{Binding UseWebSocket}" />
            </Grid>

            <StackPanel Margin="0,4,0,10" Orientation="Horizontal">
                <Button MinWidth="120" Padding="8,2" Command="{Binding TestConnectionCommand}" Content="Test connection" />
                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Text="{Binding StatusMessage}" />
            </StackPanel>

            <!--  Channels  -->
            <TextBlock Margin="0,8,0,6" FontWeight="Bold" Text="Switch channels" />

            <DataGrid
                MinHeight="160"
                MaxHeight="320"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                HeadersVisibility="Column"
                ItemsSource="{Binding Channels}">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="*" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Header="Name" />

                    <DataGridTemplateColumn Width="2*" Header="Entity">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox
                                    IsEditable="True"
                                    DisplayMemberPath="EntityId"
                                    SelectedValuePath="EntityId"
                                    ItemsSource="{Binding DataContext.AvailableEntities, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    SelectedValue="{Binding EntityId, UpdateSourceTrigger=PropertyChanged}"
                                    Text="{Binding EntityId, UpdateSourceTrigger=LostFocus}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="Auto" Header="Type">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox
                                    MinWidth="90"
                                    ItemsSource="{Binding DataContext.ChannelTypes, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="Auto" Header="Direction">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox
                                    MinWidth="100"
                                    ItemsSource="{Binding DataContext.ChannelDirections, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    SelectedItem="{Binding Direction, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button
                                    Padding="6,1"
                                    Command="{Binding DataContext.RemoveChannelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Content="Remove" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                <Button MinWidth="110" Padding="8,2" Command="{Binding AddChannelCommand}" Content="Add channel" />
                <Button Margin="8,0,0,0" MinWidth="110" Padding="8,2" Command="{Binding SaveCommand}" Content="Save" />
            </StackPanel>

            <TextBlock
                Margin="0,10,0,0"
                FontStyle="Italic"
                TextWrapping="Wrap"
                Text="After saving, connect the 'Home Assistant Switch' device from Equipment &gt; Switch. Binary = on/off, Stepped = discrete options (e.g. select), Analog = numeric (min/max/step from the entity)." />

        </StackPanel>
    </DataTemplate>
</ResourceDictionary>
